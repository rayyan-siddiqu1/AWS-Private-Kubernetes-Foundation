apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana
  namespace: "{{ monitoring_namespace }}"
  annotations:
    # cert-manager issues a self-signed certificate for this host.
    cert-manager.io/cluster-issuer: "{{ cert_manager_cluster_issuer_name }}"
spec:
  ingressClassName: nginx
  rules:
    - host: "{{ grafana_hostname }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                # kube-prometheus-stack names the Grafana service after the release.
                name: "{{ monitoring_release_name }}-grafana"
                port:
                  number: 80
  tls:
    - hosts:
        - "{{ grafana_hostname }}"
      secretName: grafana-tls
