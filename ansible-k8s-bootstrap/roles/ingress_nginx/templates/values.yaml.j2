controller:
  service:
    type: NodePort
    nodePorts:
      http: {{ ingress_nginx_http_nodeport }}
      https: {{ ingress_nginx_https_nodeport }}

  metrics:
    enabled: true
    serviceMonitor:
      # Disabled here — kube-prometheus-stack CRDs (ServiceMonitor) are not yet
      # installed at this point in the play order. Prometheus will scrape NGINX
      # metrics via pod annotation discovery once monitoring is installed.
      enabled: false

  config:
    use-forwarded-headers: "true"
    compute-full-forwarded-for: "true"
    use-proxy-protocol: "false"
