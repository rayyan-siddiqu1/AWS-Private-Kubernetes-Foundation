---
# frontend nginx.conf — proxies /api/ to backend via Consul Connect upstream.
# Consul injects the backend upstream listener at localhost:9090.
apiVersion: v1
kind: ConfigMap
metadata:
  name: frontend-nginx-conf
  namespace: "{{ sample_app_namespace }}"
data:
  nginx.conf: |
    events {}
    http {
      server {
        listen 80;

        location / {
          root /usr/share/nginx/html;
          index index.html;
        }

        # Proxy /api/ to the backend via Consul Connect upstream (localhost:9090).
        location /api/ {
          proxy_pass http://127.0.0.1:9090/;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
        }
      }
    }
---
# Dedicated ServiceAccount — name matches the Consul service name "frontend".
# The consul-k8s-auth-method binding rule maps serviceaccount.name → Consul
# service identity, so this pod gets a token scoped to "frontend" only.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: frontend
  namespace: "{{ sample_app_namespace }}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: "{{ sample_app_namespace }}"
  labels:
    app: frontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
      annotations:
        consul.hashicorp.com/connect-inject: "true"
        consul.hashicorp.com/service-port: "80"
        consul.hashicorp.com/connect-service-upstreams: "backend:9090"
    spec:
      serviceAccountName: frontend
      containers:
        - name: frontend
          image: nginx:1.27-alpine
          ports:
            - containerPort: 80
              name: http
          volumeMounts:
            - name: nginx-conf
              mountPath: /etc/nginx/nginx.conf
              subPath: nginx.conf
          resources:
            requests:
              cpu: 10m
              memory: 16Mi
            limits:
              cpu: 100m
              memory: 32Mi
      volumes:
        - name: nginx-conf
          configMap:
            name: frontend-nginx-conf
---
apiVersion: v1
kind: Service
metadata:
  name: frontend
  namespace: "{{ sample_app_namespace }}"
  labels:
    app: frontend
spec:
  selector:
    app: frontend
  ports:
    - name: http
      port: 80
      targetPort: 80
