# Consul client agent configuration
# Generated by Ansible — consul_vm_agent role
# Do not edit manually; changes will be overwritten on playbook re-run.

datacenter = "{{ consul_datacenter }}"
data_dir   = "/opt/consul"

# Client mode — this host does not participate in Raft consensus.
server = false

# Join the Consul server cluster via the Kubernetes NodePort.
# retry_join is used so the agent retries on startup if the server is
# temporarily unreachable (e.g., during cluster restarts).
retry_join = ["{{ consul_server_host }}:{{ consul_server_gossip_port }}"]

# Bind to all interfaces so Consul can gossip with the k8s cluster.
bind_addr   = "0.0.0.0"
client_addr = "127.0.0.1"

# Enable the HTTP API on loopback only (service registration, health checks).
ports {
  http  = {{ consul_server_http_port }}
  grpc  = -1
  https = -1
}

# Log level — reduce to "warn" in production.
log_level = "INFO"

# Service configuration directory — place *.hcl or *.json files here
# to register services and health checks.
config_dir = "/etc/consul.d"
